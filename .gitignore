.claude/worktrees/

# Environment / secrets — never commit credentials
.env
.env.*
!.env.example

# Wrangler — block all wrangler config and cache (Pages deploys natively)
wrangler.toml
wrangler.jsonc
.wrangler/

# Cloudflare Pages Functions local secrets — never commit.
# CLERK_SECRET_KEY (and later STRIPE_SECRET_KEY etc.) live here locally;
# production sets them via `wrangler pages secret put`.
.dev.vars
.dev.vars.*

# Node deps for Pages Functions — installed at build from package-lock.json,
# never committed.
node_modules/

# Large binary / video files — host externally (Cloudflare R2, YouTube, etc.)
*.mp4
*.mov
*.avi
*.webm
*.mkv

# Scratch / drafts / raw sources — never publish to the static site root.
# Cloudflare Pages serves the repo root verbatim, so any of these committed
# at root become world-readable. Keep working drafts out of the deploy.
scratch/
scratch_draft.txt
*.draft
*.draft.*
itibar-source.md
DHL.txt
temp.css

# Python cache
__pycache__/
*.pyc
*.pyo

# Local build / migration helpers — not part of the published site
migrate.ps1
fix_arabic_order.py
strip_scholar_tashkeel.py
tmp_src.txt
