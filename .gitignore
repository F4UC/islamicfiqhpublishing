.claude/worktrees/

# Environment / secrets — never commit credentials
.env
.env.*
!.env.example

# Wrangler — block all wrangler config and cache (Workers not used; Pages deploys natively)
wrangler.toml
wrangler.jsonc
.wrangler/

# Large binary / video files — host externally (Cloudflare R2, YouTube, etc.)
*.mp4
*.mov
*.avi
*.webm
*.mkv
